{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:ListBucket",
        "s3:ListBucketMultipartUploads",
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload",
        "s3:ListMultipartUploadParts"
      ],
      "Resource": [
        "arn:aws:s3:::sol-arquivos",
        "arn:aws:s3:::sol-arquivos/*",
        "arn:aws:s3:::sol-appci",
        "arn:aws:s3:::sol-appci/*",
        "arn:aws:s3:::sol-guias",
        "arn:aws:s3:::sol-guias/*",
        "arn:aws:s3:::sol-laudos",
        "arn:aws:s3:::sol-laudos/*",
        "arn:aws:s3:::sol-decisoes",
        "arn:aws:s3:::sol-decisoes/*",
        "arn:aws:s3:::sol-temp",
        "arn:aws:s3:::sol-temp/*"
      ]
    }
  ]
}
