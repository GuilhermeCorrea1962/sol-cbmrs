{
  "realm": "sol",
  "displayName": "SOL - Sistema Online de Licenciamento",
  "displayNameHtml": "<b>SOL</b> CBM-RS",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "failureFactor": 5,
  "waitIncrementSeconds": 60,
  "maxFailureWaitSeconds": 900,
  "accessTokenLifespan": 3600,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionMaxLifespan": 2592000,
  "roles": {
    "realm": [
      { "name": "CIDADAO",        "description": "Cidadao comum - acesso basico ao portal" },
      { "name": "RT",             "description": "Responsavel Tecnico - submete e acompanha PPCIs" },
      { "name": "ANALISTA",       "description": "Analista de PPCI - realiza analise tecnica" },
      { "name": "INSPETOR",       "description": "Inspetor de vistoria - realiza vistorias presenciais" },
      { "name": "ADMIN",          "description": "Administrador do sistema SOL" },
      { "name": "CHEFE_SSEG_BBM", "description": "Chefe da Secao de Segurança do BBM - julga recursos 1a instancia" }
    ]
  },
  "clients": [
    {
      "clientId": "sol-frontend",
      "name": "SOL Frontend Angular",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost/*",
        "http://localhost:80/*",
        "http://localhost:4200/*"
      ],
      "webOrigins": [
        "http://localhost",
        "http://localhost:80",
        "http://localhost:4200"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["openid", "profile", "email", "roles"]
    },
    {
      "clientId": "sol-backend",
      "name": "SOL Backend Spring Boot",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "protocol": "openid-connect"
    }
  ],
  "clientScopes": [
    {
      "name": "roles",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "foo",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        }
      ]
    }
  ],
  "passwordPolicy": "length(8) and digits(1) and upperCase(1) and specialChars(1)",
  "smtpServer": {
    "host": "localhost",
    "port": "1025",
    "from": "sol-noreply@cbm.rs.gov.br",
    "fromDisplayName": "SOL CBM-RS",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  }
}
