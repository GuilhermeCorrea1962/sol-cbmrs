<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
             targetNamespace="http://solcbm.procergs.rs.gov.br/bpmn"
             id="definitions_P12">

  <!-- ============================================================ -->
  <!-- PROCESSO 12 – EXTINÇÃO DE LICENCIAMENTO                      -->
  <!-- Fluxo: cidadão ou ADM solicita extinção → valida situação    -->
  <!-- do alvará → ADM registra extinção → status EXTINGUIDO →      -->
  <!-- notifica responsável técnico e demais interessados           -->
  <!-- ============================================================ -->
  <process id="Proc_12" name="12 - Extinção de Licenciamento" isExecutable="false">

    <startEvent id="P12_Start" name="Pedido de&#10;Extinção Iniciado">
      <outgoing>P12_sf01</outgoing>
    </startEvent>

    <userTask id="P12_T01" name="Registrar Solicitação&#10;de Extinção (Cidadão/ADM)">
      <incoming>P12_sf01</incoming>
      <outgoing>P12_sf02</outgoing>
    </userTask>

    <exclusiveGateway id="P12_GW01" name="Situação do Alvará&#10;Permite Extinção?">
      <incoming>P12_sf02</incoming>
      <outgoing>P12_sf03</outgoing>
      <outgoing>P12_sf04</outgoing>
    </exclusiveGateway>

    <endEvent id="P12_EndErr" name="Erro: Situação&#10;Inválida">
      <incoming>P12_sf03</incoming>
      <errorEventDefinition id="P12_ErrDef"/>
    </endEvent>

    <userTask id="P12_T02" name="ADM Analisa e Confirma&#10;Extinção no Sistema">
      <incoming>P12_sf04</incoming>
      <outgoing>P12_sf05</outgoing>
    </userTask>

    <serviceTask id="P12_T03" name="Atualizar Status do&#10;Licenciamento: EXTINGUIDO">
      <incoming>P12_sf05</incoming>
      <outgoing>P12_sf06</outgoing>
    </serviceTask>

    <serviceTask id="P12_T04" name="Notificar RT e Demais&#10;Interessados por E-mail">
      <incoming>P12_sf06</incoming>
      <outgoing>P12_sf07</outgoing>
    </serviceTask>

    <endEvent id="P12_End" name="Extinção&#10;Registrada com Sucesso">
      <incoming>P12_sf07</incoming>
    </endEvent>

    <sequenceFlow id="P12_sf01" sourceRef="P12_Start"  targetRef="P12_T01"/>
    <sequenceFlow id="P12_sf02" sourceRef="P12_T01"    targetRef="P12_GW01"/>
    <sequenceFlow id="P12_sf03" name="Não (bloqueia)" sourceRef="P12_GW01" targetRef="P12_EndErr"/>
    <sequenceFlow id="P12_sf04" name="Sim"             sourceRef="P12_GW01" targetRef="P12_T02"/>
    <sequenceFlow id="P12_sf05" sourceRef="P12_T02"    targetRef="P12_T03"/>
    <sequenceFlow id="P12_sf06" sourceRef="P12_T03"    targetRef="P12_T04"/>
    <sequenceFlow id="P12_sf07" sourceRef="P12_T04"    targetRef="P12_End"/>
  </process>

  <bpmndi:BPMNDiagram id="diagram_P12">
    <bpmndi:BPMNPlane id="plane_P12" bpmnElement="Proc_12">
      <bpmndi:BPMNShape id="shape_P12_Start" bpmnElement="P12_Start">
        <omgdc:Bounds x="102" y="242" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_P12_T01" bpmnElement="P12_T01">
        <omgdc:Bounds x="210" y="220" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_P12_GW01" bpmnElement="P12_GW01" isMarkerVisible="true">
        <omgdc:Bounds x="430" y="235" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_P12_EndErr" bpmnElement="P12_EndErr" isMarkerVisible="true">
        <omgdc:Bounds x="437" y="102" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_P12_T02" bpmnElement="P12_T02">
        <omgdc:Bounds x="540" y="220" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_P12_T03" bpmnElement="P12_T03">
        <omgdc:Bounds x="760" y="220" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_P12_T04" bpmnElement="P12_T04">
        <omgdc:Bounds x="980" y="220" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_P12_End" bpmnElement="P12_End">
        <omgdc:Bounds x="1212" y="242" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="edge_P12_sf01" bpmnElement="P12_sf01">
        <omgdi:waypoint x="138" y="260"/>
        <omgdi:waypoint x="210" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P12_sf02" bpmnElement="P12_sf02">
        <omgdi:waypoint x="380" y="260"/>
        <omgdi:waypoint x="430" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P12_sf03" bpmnElement="P12_sf03">
        <omgdi:waypoint x="455" y="235"/>
        <omgdi:waypoint x="455" y="138"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P12_sf04" bpmnElement="P12_sf04">
        <omgdi:waypoint x="480" y="260"/>
        <omgdi:waypoint x="540" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P12_sf05" bpmnElement="P12_sf05">
        <omgdi:waypoint x="710" y="260"/>
        <omgdi:waypoint x="760" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P12_sf06" bpmnElement="P12_sf06">
        <omgdi:waypoint x="930" y="260"/>
        <omgdi:waypoint x="980" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P12_sf07" bpmnElement="P12_sf07">
        <omgdi:waypoint x="1150" y="260"/>
        <omgdi:waypoint x="1212" y="260"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
