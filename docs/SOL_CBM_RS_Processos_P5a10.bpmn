  <!-- ============================================================ -->
  <!-- PROCESSO 10: RECURSO / CONTESTAÇÃO                          -->
  <!-- ============================================================ -->
  <process id="Proc_10" name="10 - Recurso e Contestação de CIA/CIV" isExecutable="false">
    <startEvent id="P10_Start" name="Cidadão contesta CIA ou CIV recebido">
      <outgoing>P10_F01</outgoing>
    </startEvent>
    <userTask id="P10_T01" name="Preencher formulário de recurso">
      <incoming>P10_F01</incoming><outgoing>P10_F02</outgoing>
    </userTask>
    <serviceTask id="P10_T02" name="Validar campos obrigatórios: TipoSolicitacao (RN-073), TipoRecurso (RN-074), Instância 1 ou 2 (RN-075), FundamentacaoLegal (RN-076), idLicenciamento (RN-077), idArquivoCiaCiv (RN-078), ao menos 1 envolvido (RN-079)">
      <incoming>P10_F02</incoming><outgoing>P10_F03</outgoing>
    </serviceTask>
    <userTask id="P10_T03" name="Anexar documentação complementar de suporte (PDF obrigatório)">
      <incoming>P10_F03</incoming><outgoing>P10_F04</outgoing>
    </userTask>
    <serviceTask id="P10_T04" name="Registrar recurso no sistema">
      <incoming>P10_F04</incoming><outgoing>P10_F05</outgoing>
    </serviceTask>
    <exclusiveGateway id="P10_G01" name="Instância do recurso?">
      <incoming>P10_F05</incoming><outgoing>P10_F06</outgoing><outgoing>P10_F07</outgoing>
    </exclusiveGateway>
    <userTask id="P10_T05" name="Comissão analisa recurso em 1ª Instância (CIA)">
      <incoming>P10_F06</incoming><outgoing>P10_F08</outgoing>
    </userTask>
    <userTask id="P10_T06" name="Comissão analisa recurso em 2ª Instância (avalista externo)">
      <incoming>P10_F07</incoming><outgoing>P10_F09</outgoing>
    </userTask>
    <exclusiveGateway id="P10_G02" name="Decisão do recurso?">
      <incoming>P10_F08</incoming><incoming>P10_F09</incoming>
      <outgoing>P10_F10</outgoing><outgoing>P10_F11</outgoing>
    </exclusiveGateway>
    <serviceTask id="P10_T07" name="Rever resultado da análise técnica (recalcular CA/CIA)">
      <incoming>P10_F10</incoming><outgoing>P10_F12</outgoing>
    </serviceTask>
    <serviceTask id="P10_T08" name="Notificar cidadão: recurso PROVIDO — análise revisada">
      <incoming>P10_F12</incoming><outgoing>P10_F13</outgoing>
    </serviceTask>
    <endEvent id="P10_End_Provido" name="Recurso provido — licenciamento revisado">
      <incoming>P10_F13</incoming>
    </endEvent>
    <serviceTask id="P10_T09" name="Manter decisão original — emitir nova CIA/CIV">
      <incoming>P10_F11</incoming><outgoing>P10_F14</outgoing>
    </serviceTask>
    <serviceTask id="P10_T10" name="Notificar cidadão: recurso IMPROVIDO">
      <incoming>P10_F14</incoming><outgoing>P10_F15</outgoing>
    </serviceTask>
    <endEvent id="P10_End_Improvido" name="Recurso improvido — decisão mantida">
      <incoming>P10_F15</incoming>
    </endEvent>
    <sequenceFlow id="P10_F01" sourceRef="P10_Start" targetRef="P10_T01"/>
    <sequenceFlow id="P10_F02" sourceRef="P10_T01" targetRef="P10_T02"/>
    <sequenceFlow id="P10_F03" sourceRef="P10_T02" targetRef="P10_T03"/>
    <sequenceFlow id="P10_F04" sourceRef="P10_T03" targetRef="P10_T04"/>
    <sequenceFlow id="P10_F05" sourceRef="P10_T04" targetRef="P10_G01"/>
    <sequenceFlow id="P10_F06" name="1ª Instância" sourceRef="P10_G01" targetRef="P10_T05"/>
    <sequenceFlow id="P10_F07" name="2ª Instância" sourceRef="P10_G01" targetRef="P10_T06"/>
    <sequenceFlow id="P10_F08" sourceRef="P10_T05" targetRef="P10_G02"/>
    <sequenceFlow id="P10_F09" sourceRef="P10_T06" targetRef="P10_G02"/>
    <sequenceFlow id="P10_F10" name="Provido" sourceRef="P10_G02" targetRef="P10_T07"/>
    <sequenceFlow id="P10_F11" name="Improvido" sourceRef="P10_G02" targetRef="P10_T09"/>
    <sequenceFlow id="P10_F12" sourceRef="P10_T07" targetRef="P10_T08"/>
    <sequenceFlow id="P10_F13" sourceRef="P10_T08" targetRef="P10_End_Provido"/>
    <sequenceFlow id="P10_F14" sourceRef="P10_T09" targetRef="P10_T10"/>
    <sequenceFlow id="P10_F15" sourceRef="P10_T10" targetRef="P10_End_Improvido"/>
  </process>

