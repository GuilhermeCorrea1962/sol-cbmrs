      </bpmndi:BPMNShape>

      <!-- GW_AN_001 -->
      <bpmndi:BPMNShape id="Shape_GW_AN_001" bpmnElement="GW_AN_001" isMarkerVisible="true">
        <dc:Bounds x="1055" y="1075" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1038" y="1132" width="84" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- T_AN_005 (APROVADO — acima) -->
      <bpmndi:BPMNShape id="Shape_T_AN_005" bpmnElement="T_AN_005">
        <dc:Bounds x="1165" y="955" width="140" height="80"/>
      </bpmndi:BPMNShape>

