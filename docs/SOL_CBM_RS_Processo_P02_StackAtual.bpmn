    <sequenceFlow id="SF_038" name="REPROVADO" sourceRef="GW_AN_001" targetRef="T_AN_006"/>
    <sequenceFlow id="SF_039" name="CANCELAR" sourceRef="GW_AN_001" targetRef="T_AN_007"/>
