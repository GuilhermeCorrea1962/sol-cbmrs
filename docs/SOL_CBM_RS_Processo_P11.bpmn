<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
             targetNamespace="http://solcbm.procergs.rs.gov.br/bpmn"
             id="definitions_P11">

  <!-- ============================================================ -->
  <!-- PROCESSO 11 – PAGAMENTO E GERAÇÃO DE BOLETO                  -->
  <!-- Fluxo: solicitação em AGUARDANDO_PAGAMENTO → cidadão gera    -->
  <!-- ou reutiliza boleto → efetua pagamento → job confirma        -->
  <!-- retorno bancário → status avança para AGUARDANDO_ACEITE      -->
  <!-- ============================================================ -->
  <process id="Proc_11" name="11 - Pagamento e Geração de Boleto" isExecutable="false">

    <startEvent id="P11_Start" name="Solicitação em&#10;AGUARDANDO_PAGAMENTO">
      <outgoing>P11_sf01</outgoing>
    </startEvent>

    <userTask id="P11_T01" name="Verificar se Existe&#10;Boleto Vigente">
      <incoming>P11_sf01</incoming>
      <outgoing>P11_sf02</outgoing>
    </userTask>

    <exclusiveGateway id="P11_GW01" name="Boleto&#10;Vigente?">
      <incoming>P11_sf02</incoming>
      <outgoing>P11_sf03</outgoing>
      <outgoing>P11_sf04</outgoing>
    </exclusiveGateway>

    <serviceTask id="P11_T02" name="Gerar Novo Boleto&#10;(Integração Bancária)">
      <incoming>P11_sf03</incoming>
      <outgoing>P11_sf05</outgoing>
    </serviceTask>

    <userTask id="P11_T03" name="Exibir Boleto&#10;Existente ao Cidadão">
      <incoming>P11_sf04</incoming>
      <outgoing>P11_sf06</outgoing>
    </userTask>

    <exclusiveGateway id="P11_GW02" name="Merge">
      <incoming>P11_sf05</incoming>
      <incoming>P11_sf06</incoming>
      <outgoing>P11_sf07</outgoing>
    </exclusiveGateway>

    <userTask id="P11_T04" name="Cidadão Efetua&#10;Pagamento do Boleto">
      <incoming>P11_sf07</incoming>
      <outgoing>P11_sf08</outgoing>
    </userTask>

    <serviceTask id="P11_T05" name="Job: Verificar&#10;Retorno Bancário">
      <incoming>P11_sf08</incoming>
      <incoming>P11_sf11</incoming>
      <outgoing>P11_sf09</outgoing>
    </serviceTask>

    <exclusiveGateway id="P11_GW03" name="Pagamento&#10;Confirmado?">
      <incoming>P11_sf09</incoming>
      <outgoing>P11_sf10</outgoing>
      <outgoing>P11_sf11</outgoing>
    </exclusiveGateway>

    <serviceTask id="P11_T06" name="Atualizar Status:&#10;AGUARDANDO_ACEITE">
      <incoming>P11_sf10</incoming>
      <outgoing>P11_sf12</outgoing>
    </serviceTask>

    <endEvent id="P11_End" name="Pagamento&#10;Registrado">
      <incoming>P11_sf12</incoming>
    </endEvent>

    <sequenceFlow id="P11_sf01" sourceRef="P11_Start"  targetRef="P11_T01"/>
    <sequenceFlow id="P11_sf02" sourceRef="P11_T01"    targetRef="P11_GW01"/>
    <sequenceFlow id="P11_sf03" name="Não" sourceRef="P11_GW01" targetRef="P11_T02"/>
    <sequenceFlow id="P11_sf04" name="Sim" sourceRef="P11_GW01" targetRef="P11_T03"/>
    <sequenceFlow id="P11_sf05" sourceRef="P11_T02"    targetRef="P11_GW02"/>
    <sequenceFlow id="P11_sf06" sourceRef="P11_T03"    targetRef="P11_GW02"/>
    <sequenceFlow id="P11_sf07" sourceRef="P11_GW02"   targetRef="P11_T04"/>
    <sequenceFlow id="P11_sf08" sourceRef="P11_T04"    targetRef="P11_T05"/>
    <sequenceFlow id="P11_sf09" sourceRef="P11_T05"    targetRef="P11_GW03"/>
    <sequenceFlow id="P11_sf10" name="Sim" sourceRef="P11_GW03" targetRef="P11_T06"/>
    <sequenceFlow id="P11_sf11" name="Não" sourceRef="P11_GW03" targetRef="P11_T05"/>
    <sequenceFlow id="P11_sf12" sourceRef="P11_T06"    targetRef="P11_End"/>
  </process>

  <bpmndi:BPMNDiagram id="diagram_P11">
    <bpmndi:BPMNPlane id="plane_P11" bpmnElement="Proc_11">
      <bpmndi:BPMNShape id="shape_P11_Start" bpmnElement="P11_Start">
        <omgdc:Bounds x="102" y="242" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_P11_T01" bpmnElement="P11_T01">
        <omgdc:Bounds x="210" y="220" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_P11_GW01" bpmnElement="P11_GW01" isMarkerVisible="true">
        <omgdc:Bounds x="395" y="235" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_P11_T02" bpmnElement="P11_T02">
        <omgdc:Bounds x="490" y="100" width="150" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_P11_T03" bpmnElement="P11_T03">
        <omgdc:Bounds x="490" y="340" width="150" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_P11_GW02" bpmnElement="P11_GW02" isMarkerVisible="true">
        <omgdc:Bounds x="700" y="235" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_P11_T04" bpmnElement="P11_T04">
        <omgdc:Bounds x="810" y="220" width="150" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_P11_T05" bpmnElement="P11_T05">
        <omgdc:Bounds x="1020" y="220" width="150" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_P11_GW03" bpmnElement="P11_GW03" isMarkerVisible="true">
        <omgdc:Bounds x="1230" y="235" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_P11_T06" bpmnElement="P11_T06">
        <omgdc:Bounds x="1340" y="220" width="160" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_P11_End" bpmnElement="P11_End">
        <omgdc:Bounds x="1562" y="242" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="edge_P11_sf01" bpmnElement="P11_sf01">
        <omgdi:waypoint x="138" y="260"/>
        <omgdi:waypoint x="210" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P11_sf02" bpmnElement="P11_sf02">
        <omgdi:waypoint x="350" y="260"/>
        <omgdi:waypoint x="395" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P11_sf03" bpmnElement="P11_sf03">
        <omgdi:waypoint x="420" y="235"/>
        <omgdi:waypoint x="420" y="140"/>
        <omgdi:waypoint x="490" y="140"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P11_sf04" bpmnElement="P11_sf04">
        <omgdi:waypoint x="420" y="285"/>
        <omgdi:waypoint x="420" y="380"/>
        <omgdi:waypoint x="490" y="380"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P11_sf05" bpmnElement="P11_sf05">
        <omgdi:waypoint x="640" y="140"/>
        <omgdi:waypoint x="725" y="140"/>
        <omgdi:waypoint x="725" y="235"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P11_sf06" bpmnElement="P11_sf06">
        <omgdi:waypoint x="640" y="380"/>
        <omgdi:waypoint x="725" y="380"/>
        <omgdi:waypoint x="725" y="285"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P11_sf07" bpmnElement="P11_sf07">
        <omgdi:waypoint x="750" y="260"/>
        <omgdi:waypoint x="810" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P11_sf08" bpmnElement="P11_sf08">
        <omgdi:waypoint x="960" y="260"/>
        <omgdi:waypoint x="1020" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P11_sf09" bpmnElement="P11_sf09">
        <omgdi:waypoint x="1170" y="260"/>
        <omgdi:waypoint x="1230" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P11_sf10" bpmnElement="P11_sf10">
        <omgdi:waypoint x="1280" y="260"/>
        <omgdi:waypoint x="1340" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P11_sf11" bpmnElement="P11_sf11">
        <omgdi:waypoint x="1255" y="285"/>
        <omgdi:waypoint x="1255" y="440"/>
        <omgdi:waypoint x="1095" y="440"/>
        <omgdi:waypoint x="1095" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P11_sf12" bpmnElement="P11_sf12">
        <omgdi:waypoint x="1500" y="260"/>
        <omgdi:waypoint x="1562" y="260"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
