        <omgdi:waypoint x="1090" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P09_sf09" bpmnElement="P09_sf09">
        <omgdi:waypoint x="1115" y="235"/>
        <omgdi:waypoint x="1115" y="180"/>
        <omgdi:waypoint x="1200" y="180"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P09_sf10" bpmnElement="P09_sf10">
        <omgdi:waypoint x="1115" y="285"/>
        <omgdi:waypoint x="1115" y="380"/>
        <omgdi:waypoint x="1200" y="380"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P09_sf11" bpmnElement="P09_sf11">
        <omgdi:waypoint x="1360" y="180"/>
        <omgdi:waypoint x="1445" y="180"/>
        <omgdi:waypoint x="1445" y="235"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P09_sf12" bpmnElement="P09_sf12">
        <omgdi:waypoint x="1360" y="380"/>
        <omgdi:waypoint x="1445" y="380"/>
        <omgdi:waypoint x="1445" y="285"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P09_sf13" bpmnElement="P09_sf13">
        <omgdi:waypoint x="1470" y="260"/>
