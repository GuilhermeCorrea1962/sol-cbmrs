        <di:waypoint x="1488" y="207"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_Vencidos_Rotina_di" bpmnElement="SF_Vencidos_Rotina">
        <di:waypoint x="1618" y="207"/>
