        <dc:Bounds x="160" y="80" width="2020" height="640" />
      </bpmndi:BPMNShape>

      <!-- Lanes P11-A -->
      <bpmndi:BPMNShape id="Shape_Lane_Cidadao_A" bpmnElement="Lane_Cidadao_A" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="1990" height="210" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Sistema_A" bpmnElement="Lane_Sistema_A" isHorizontal="true">
        <dc:Bounds x="190" y="290" width="1990" height="230" />
      </bpmndi:BPMNShape>
