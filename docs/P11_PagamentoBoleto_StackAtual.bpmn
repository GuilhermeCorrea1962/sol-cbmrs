        <bpmndi:BPMNLabel><dc:Bounds x="752" y="268" width="86" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ST_VerifBoletoAnterior -->
      <bpmndi:BPMNShape id="Shape_ST_VerifBoletoAnterior" bpmnElement="ST_VerifBoletoAnterior">
