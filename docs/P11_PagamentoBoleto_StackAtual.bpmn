      <bpmndi:BPMNShape id="Shape_UT_DownloadBoleto" bpmnElement="UT_DownloadBoleto">
        <dc:Bounds x="1790" y="143" width="150" height="80" />
      </bpmndi:BPMNShape>

      <!-- UT_EfetuarPagamento -->
      <bpmndi:BPMNShape id="Shape_UT_EfetuarPagamento" bpmnElement="UT_EfetuarPagamento">
        <dc:Bounds x="2000" y="143" width="150" height="80" />
      </bpmndi:BPMNShape>

      <!-- End_BoletoEmitido -->
      <bpmndi:BPMNShape id="Shape_End_BoletoEmitido" bpmnElement="End_BoletoEmitido">
        <dc:Bounds x="2122" y="165" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="2094" y="209" width="92" height="40" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ═══ EDGES P11-A ═══ -->
      <bpmndi:BPMNEdge id="Edge_Start_To_ListarResp" bpmnElement="Flow_Start_To_ListarResp">
        <di:waypoint x="288" y="183" /><di:waypoint x="340" y="183" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_ListarResp_To_Solicitar" bpmnElement="Flow_ListarResp_To_Solicitar">
        <di:waypoint x="490" y="183" /><di:waypoint x="550" y="183" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Solicitar_To_ValidarPrecond" bpmnElement="Flow_Solicitar_To_ValidarPrecond">
        <di:waypoint x="625" y="223" /><di:waypoint x="625" y="353" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_ValidarPrecond_To_GW" bpmnElement="Flow_ValidarPrecond_To_GW">
        <di:waypoint x="710" y="393" /><di:waypoint x="770" y="393" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_GW_PrecondOK_Sim" bpmnElement="Flow_GW_PrecondOK_Sim">
        <di:waypoint x="820" y="393" /><di:waypoint x="880" y="393" />
        <bpmndi:BPMNLabel><dc:Bounds x="841" y="375" width="18" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_GW_PrecondOK_Nao" bpmnElement="Flow_GW_PrecondOK_Nao">
        <di:waypoint x="795" y="368" /><di:waypoint x="795" y="338" />
        <bpmndi:BPMNLabel><dc:Bounds x="736" y="347" width="52" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_VerifBoleto_To_GW" bpmnElement="Flow_VerifBoleto_To_GW">
        <di:waypoint x="1030" y="393" /><di:waypoint x="1090" y="393" />
      </bpmndi:BPMNEdge>
