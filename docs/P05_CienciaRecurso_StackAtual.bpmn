      <lane id="Lane_Sistema" name="Sistema SOL — Backend Java EE">
        <flowNodeRef>T03A_RegistrarCienciaManual</flowNodeRef>
        <flowNodeRef>T03B_RegistrarCienciaAutomatica</flowNodeRef>
        <flowNodeRef>GW01_JoinCiencia</flowNodeRef>
        <flowNodeRef>T04_AtualizarLicenciamento</flowNodeRef>
        <flowNodeRef>GW02_Aprovado</flowNodeRef>
        <flowNodeRef>GW03_TipoDoc</flowNodeRef>
        <flowNodeRef>End_AlvaraVigente</flowNodeRef>
