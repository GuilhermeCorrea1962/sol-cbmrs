        <flowNodeRef>T20_AtualizarEstado</flowNodeRef>
        <flowNodeRef>T22_RegistrarCienciaManualResp</flowNodeRef>
        <flowNodeRef>T22B_CienciaAutomaticaResp</flowNodeRef>
        <flowNodeRef>GW09_JoinCienciaResp</flowNodeRef>
