        <omgdi:waypoint x="1700" y="380"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P07_sf13" bpmnElement="P07_sf13">
        <omgdi:waypoint x="1880" y="140"/>
