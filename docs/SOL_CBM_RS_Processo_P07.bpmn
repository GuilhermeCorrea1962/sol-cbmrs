        <omgdi:waypoint x="1700" y="140"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P07_sf11" bpmnElement="P07_sf11">
        <omgdi:waypoint x="1640" y="260"/>
        <omgdi:waypoint x="1700" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P07_sf12" bpmnElement="P07_sf12">
        <omgdi:waypoint x="1615" y="285"/>
