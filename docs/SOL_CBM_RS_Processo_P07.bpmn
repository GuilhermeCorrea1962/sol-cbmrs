      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_P07_sf15" bpmnElement="P07_sf15">
        <omgdi:waypoint x="1880" y="380"/>
        <omgdi:waypoint x="1942" y="380"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
