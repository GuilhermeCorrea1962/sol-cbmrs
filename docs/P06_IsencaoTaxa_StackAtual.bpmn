        <omgdi:waypoint x="1980" y="600" /><omgdi:waypoint x="2020" y="600" /><omgdi:waypoint x="2020" y="145" /><omgdi:waypoint x="1952" y="145" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="SF_ReprovarAuto_to_Marco_di" bpmnElement="SF_ReprovarAuto_to_Marco">
