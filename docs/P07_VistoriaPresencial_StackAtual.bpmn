      <!-- BE TransicionarCienciaCIV → RT VisualizarCIV (sobe muitas lanes) -->
      <bpmndi:BPMNEdge id="Flow_TransicionarCIV_VisualizarCIV_di" bpmnElement="Flow_TransicionarCIV_VisualizarCIV">
